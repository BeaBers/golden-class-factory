{
  "meta": {
    "name": "Tooltip",
    "source": "Radix UI Primitives",
    "ver": "1.0.0",
    "date": "2026-06-14",
    "type": "web",
    "miner": "full_miner_v6"
  },
  "hierarchy": {
    "root": "Root",
    "parts": [
      "Root",
      "Trigger",
      "Portal",
      "Content",
      "Arrow"
    ]
  },
  "props": [
    {
      "name": "open",
      "type": "boolean",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Open/expanded state",
      "uiControl": "toggle",
      "category": "state",
      "constraints": null,
      "css": null
    },
    {
      "name": "children",
      "type": "component",
      "required": true,
      "default": null,
      "allowedValues": null,
      "description": "Child elements contained within",
      "uiControl": "component_picker",
      "category": "content",
      "constraints": null,
      "css": null
    },
    {
      "name": "container",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Specify a container element to portal the content into.",
      "uiControl": "text_input",
      "category": "content",
      "constraints": null,
      "css": null
    },
    {
      "name": "defaultOpen",
      "type": "boolean",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Default open state initial",
      "uiControl": "toggle",
      "category": "content",
      "constraints": null,
      "css": null
    },
    {
      "name": "delayDuration",
      "type": "number",
      "required": false,
      "default": "700",
      "allowedValues": null,
      "description": "The duration from when the pointer enters the trigger until the tooltip gets opened.",
      "uiControl": "slider",
      "category": "behavior",
      "constraints": null,
      "css": null
    },
    {
      "name": "disableHoverableContent",
      "type": "boolean",
      "required": false,
      "default": "false",
      "allowedValues": null,
      "description": "When `true`, trying to hover the content will result in the tooltip closing as the pointer leaves the trigger.",
      "uiControl": "toggle",
      "category": "behavior",
      "constraints": null,
      "css": null
    },
    {
      "name": "forceMount",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Used to force mounting when more control is needed. Useful when controlling animation with React animation libraries.",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null,
      "css": null
    },
    {
      "name": "onEscapeKeyDown",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Event handler called when the escape key is down. Can be prevented.",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null,
      "css": null
    },
    {
      "name": "onOpenChange",
      "type": "function",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Property onOpenChange (callback)",
      "uiControl": "code_input",
      "category": "behavior",
      "constraints": null,
      "css": null
    },
    {
      "name": "onPointerDownOutside",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Event handler called when the a `pointerdown` event happens outside of the `Tooltip`. Can be prevented.",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null,
      "css": null
    },
    {
      "name": "skipDelayDuration",
      "type": "number",
      "required": false,
      "default": "300",
      "allowedValues": null,
      "description": "How much time a user has to enter another trigger without incurring a delay again.",
      "uiControl": "slider",
      "category": "behavior",
      "constraints": null,
      "css": null
    }
  ],
  "events": [
    {
      "name": "onOpenChange",
      "params": [
        "boolean"
      ],
      "description": "Fires when open/closed state changes"
    },
    {
      "name": "onClick",
      "params": [
        "React.MouseEvent"
      ],
      "description": "Fires when the component is clicked"
    },
    {
      "name": "onFocus",
      "params": [
        "React.FocusEvent"
      ],
      "description": "Fires when the component gains focus"
    },
    {
      "name": "onBlur",
      "params": [
        "React.FocusEvent"
      ],
      "description": "Fires when the component loses focus"
    }
  ]
}