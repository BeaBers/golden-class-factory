{
  "meta": {
    "name": "Tooltip",
    "source": "Radix UI Primitives",
    "ver": "1.0.0",
    "date": "2026-06-14",
    "type": "web",
    "miner": "full_miner_v5"
  },
  "hierarchy": {
    "root": "Root",
    "parts": [
      "Root",
      "Trigger",
      "Portal",
      "Content",
      "Arrow"
    ],
    "structure": {
      "Root": {
        "tag": "div",
        "children": true
      },
      "Trigger": {
        "tag": "div",
        "children": true
      },
      "Portal": {
        "tag": "div",
        "children": true
      },
      "Content": {
        "tag": "div",
        "children": true
      },
      "Arrow": {
        "tag": "div",
        "children": true
      }
    }
  },
  "props": [
    {
      "name": "defaultOpen",
      "type": "boolean",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "الحالة الافتراضية للفتح/الإغلاق",
      "uiControl": "toggle",
      "category": "content",
      "constraints": null,
      "css": null
    },
    {
      "name": "open",
      "type": "boolean",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "التحكم في فتح/إغلاق المكون",
      "uiControl": "toggle",
      "category": "content",
      "constraints": null,
      "css": null
    },
    {
      "name": "children",
      "type": "component",
      "required": true,
      "default": null,
      "allowedValues": null,
      "description": "خاصية children (مكون React)",
      "uiControl": "component_picker",
      "category": "behavior",
      "constraints": null,
      "css": null
    },
    {
      "name": "container",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Specify a container element to portal the content into.",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null,
      "css": null
    },
    {
      "name": "delayDuration",
      "type": "number",
      "required": false,
      "default": "700",
      "allowedValues": null,
      "description": "The duration from when the pointer enters the trigger until the tooltip gets opened.",
      "uiControl": "slider",
      "category": "behavior",
      "constraints": {
        "min": 0
      },
      "css": null
    },
    {
      "name": "disableHoverableContent",
      "type": "boolean",
      "required": false,
      "default": "false",
      "allowedValues": null,
      "description": "When `true`, trying to hover the content will result in the tooltip closing as the pointer leaves the trigger.",
      "uiControl": "toggle",
      "category": "behavior",
      "constraints": null,
      "css": null
    },
    {
      "name": "forceMount",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Used to force mounting when more control is needed. Useful when controlling animation with React animation libraries.",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null,
      "css": null
    },
    {
      "name": "onEscapeKeyDown",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Event handler called when the escape key is down. Can be prevented.",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null,
      "css": null
    },
    {
      "name": "onOpenChange",
      "type": "function",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "خاصية onOpenChange (دالة)",
      "uiControl": "code_input",
      "category": "behavior",
      "constraints": null,
      "css": null
    },
    {
      "name": "onPointerDownOutside",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Event handler called when the a `pointerdown` event happens outside of the `Tooltip`. Can be prevented.",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null,
      "css": null
    },
    {
      "name": "skipDelayDuration",
      "type": "number",
      "required": false,
      "default": "300",
      "allowedValues": null,
      "description": "How much time a user has to enter another trigger without incurring a delay again.",
      "uiControl": "slider",
      "category": "behavior",
      "constraints": {
        "min": 0
      },
      "css": null
    }
  ],
  "events": [
    {
      "name": "onOpenChange",
      "params": [
        "boolean"
      ],
      "description": "عند تغيير حالة الفتح/الإغلاق"
    },
    {
      "name": "onClick",
      "params": [
        "React.MouseEvent"
      ],
      "description": "عند النقر على المكون"
    },
    {
      "name": "onFocus",
      "params": [
        "React.FocusEvent"
      ],
      "description": "عند اكتساب التركيز"
    },
    {
      "name": "onBlur",
      "params": [
        "React.FocusEvent"
      ],
      "description": "عند فقدان التركيز"
    }
  ]
}