{
  "meta": {
    "name": "Accordion",
    "source": "Radix UI",
    "ver": "1.0.0",
    "date": "2026-06-13",
    "type": "web"
  },
  "sem": {
    "tag": "div",
    "container": false,
    "children": true,
    "role": "accordion"
  },
  "props": [],
  "events": [
    {
      "name": "onValueChange",
      "desc": "Expanded item changes",
      "params": [
        "string[]"
      ]
    },
    {
      "name": "onClick",
      "desc": "Clicked",
      "params": [
        "React.MouseEvent"
      ]
    },
    {
      "name": "onFocus",
      "desc": "Focused",
      "params": [
        "React.FocusEvent"
      ]
    },
    {
      "name": "onBlur",
      "desc": "Blurred",
      "params": [
        "React.FocusEvent"
      ]
    }
  ],
  "access": {
    "aria": [
      "aria-label",
      "aria-describedby",
      "aria-expanded",
      "aria-controls"
    ],
    "kb": {
      "Space": "Toggle",
      "Enter": "Toggle"
    }
  }
}