{
  "meta": {
    "name": "Collapsible",
    "source": "Radix UI",
    "ver": "1.0.0",
    "date": "2026-06-14",
    "type": "web"
  },
  "sem": {
    "tag": "div",
    "container": false,
    "children": true,
    "role": "collapsible"
  },
  "props": [
    {
      "name": "defaultOpen",
      "type": "boolean",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Whether initially open",
      "uiControl": "toggle",
      "category": "content",
      "constraints": null
    },
    {
      "name": "open",
      "type": "boolean",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Whether the component is open/visible",
      "uiControl": "toggle",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "disabled",
      "type": "boolean",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Whether the component is disabled",
      "uiControl": "toggle",
      "category": "state",
      "constraints": null
    },
    {
      "name": "onOpenChange",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "OpenChange (string)",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "forceMount",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Always mount in DOM",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "present",
      "type": "boolean",
      "required": true,
      "default": null,
      "allowedValues": null,
      "description": "present (boolean)",
      "uiControl": "toggle",
      "category": "behavior",
      "constraints": null
    }
  ],
  "events": [
    {
      "name": "onClick",
      "desc": "Clicked",
      "params": [
        "React.MouseEvent"
      ]
    },
    {
      "name": "onFocus",
      "desc": "Focused",
      "params": [
        "React.FocusEvent"
      ]
    },
    {
      "name": "onBlur",
      "desc": "Blurred",
      "params": [
        "React.FocusEvent"
      ]
    }
  ],
  "access": {
    "aria": [
      "aria-label",
      "aria-describedby"
    ],
    "kb": {}
  }
}