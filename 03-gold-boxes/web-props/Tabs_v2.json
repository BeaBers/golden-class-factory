{
  "meta": {
    "name": "Tabs",
    "source": "Radix UI",
    "ver": "1.0.0",
    "date": "2026-06-14",
    "type": "web"
  },
  "sem": {
    "tag": "div",
    "container": false,
    "children": true,
    "role": "tabs"
  },
  "props": [
    {
      "name": "value",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "The value for the selected tab, if controlled */",
      "uiControl": "text_input",
      "category": "content",
      "constraints": null
    },
    {
      "name": "defaultValue",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "The value of the tab to select by default, if uncontrolled */",
      "uiControl": "text_input",
      "category": "content",
      "constraints": null
    },
    {
      "name": "onValueChange",
      "type": "function",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "A function called when a new tab is selected */",
      "uiControl": "code_input",
      "category": "content",
      "constraints": null
    },
    {
      "name": "orientation",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "dir",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "activationMode",
      "type": "enum",
      "required": false,
      "default": "automatic",
      "allowedValues": [
        "automatic",
        "manual"
      ],
      "description": "Whether a tab is activated automatically or manually. */",
      "uiControl": "select",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "loop",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "forceMount",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    }
  ],
  "events": [
    {
      "name": "onValueChange",
      "desc": "Active tab changes",
      "params": [
        "string"
      ]
    },
    {
      "name": "onClick",
      "desc": "Clicked",
      "params": [
        "React.MouseEvent"
      ]
    },
    {
      "name": "onFocus",
      "desc": "Focused",
      "params": [
        "React.FocusEvent"
      ]
    },
    {
      "name": "onBlur",
      "desc": "Blurred",
      "params": [
        "React.FocusEvent"
      ]
    }
  ],
  "access": {
    "aria": [
      "aria-label",
      "aria-describedby",
      "aria-selected",
      "aria-tablist",
      "aria-controls"
    ],
    "kb": {
      "ArrowRight": "Next",
      "ArrowLeft": "Previous",
      "Home": "First",
      "End": "Last"
    }
  }
}