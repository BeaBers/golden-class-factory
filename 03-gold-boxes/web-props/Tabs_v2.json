{
  "meta": {
    "name": "Tabs",
    "source": "Radix UI",
    "ver": "1.0.0",
    "date": "2026-06-13",
    "type": "web"
  },
  "sem": {
    "tag": "div",
    "container": false,
    "children": true,
    "role": "tabs"
  },
  "props": [],
  "events": [
    {
      "name": "onValueChange",
      "desc": "Active tab changes",
      "params": [
        "string"
      ]
    },
    {
      "name": "onClick",
      "desc": "Clicked",
      "params": [
        "React.MouseEvent"
      ]
    },
    {
      "name": "onFocus",
      "desc": "Focused",
      "params": [
        "React.FocusEvent"
      ]
    },
    {
      "name": "onBlur",
      "desc": "Blurred",
      "params": [
        "React.FocusEvent"
      ]
    }
  ],
  "access": {
    "aria": [
      "aria-label",
      "aria-describedby",
      "aria-selected",
      "aria-tablist",
      "aria-controls"
    ],
    "kb": {
      "ArrowRight": "Next",
      "ArrowLeft": "Previous",
      "Home": "First",
      "End": "Last"
    }
  }
}