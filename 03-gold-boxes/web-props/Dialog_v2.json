{
  "meta": {
    "name": "Dialog",
    "source": "Radix UI",
    "ver": "1.0.0",
    "date": "2026-06-14",
    "type": "web"
  },
  "sem": {
    "tag": "div",
    "container": false,
    "children": true,
    "role": "dialog"
  },
  "props": [
    {
      "name": "children",
      "type": "component",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Content of the component",
      "uiControl": "component_picker",
      "category": "content",
      "constraints": null
    },
    {
      "name": "open",
      "type": "boolean",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Whether the component is open/visible",
      "uiControl": "toggle",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "defaultOpen",
      "type": "boolean",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Whether initially open",
      "uiControl": "toggle",
      "category": "content",
      "constraints": null
    },
    {
      "name": "onOpenChange",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "OpenChange (string)",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "modal",
      "type": "boolean",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Whether the component is modal",
      "uiControl": "toggle",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "container",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "ctainer (string)",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "forceMount",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Always mount in DOM",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "trapFocus",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "trapFocus (string)",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "onOpenAutoFocus",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "OpenAutoFocus (string)",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "onCloseAutoFocus",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "CloseAutoFocus (string)",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    }
  ],
  "events": [
    {
      "name": "onOpenChange",
      "desc": "Open state changes",
      "params": [
        "boolean"
      ]
    },
    {
      "name": "onClick",
      "desc": "Clicked",
      "params": [
        "React.MouseEvent"
      ]
    },
    {
      "name": "onFocus",
      "desc": "Focused",
      "params": [
        "React.FocusEvent"
      ]
    },
    {
      "name": "onBlur",
      "desc": "Blurred",
      "params": [
        "React.FocusEvent"
      ]
    }
  ],
  "access": {
    "aria": [
      "aria-label",
      "aria-describedby",
      "aria-modal",
      "aria-hidden"
    ],
    "kb": {
      "Escape": "Close",
      "Tab": "Cycle focus"
    }
  }
}