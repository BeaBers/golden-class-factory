{
  "meta": {
    "name": "Progress",
    "source": "Radix UI",
    "ver": "1.0.0",
    "date": "2026-06-14",
    "type": "web"
  },
  "sem": {
    "tag": "div",
    "container": false,
    "children": true,
    "role": "progress"
  },
  "props": [
    {
      "name": "value",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "The controlled value",
      "uiControl": "text_input",
      "category": "content",
      "constraints": null
    },
    {
      "name": "max",
      "type": "number",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "max (number)",
      "uiControl": "slider",
      "category": "dimension",
      "constraints": {
        "min": 0
      }
    },
    {
      "name": "getValueLabel",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "getValueLabel (string)",
      "uiControl": "text_input",
      "category": "content",
      "constraints": null
    }
  ],
  "events": [
    {
      "name": "onValueChange",
      "desc": "Progress value changes",
      "params": [
        "number"
      ]
    },
    {
      "name": "onClick",
      "desc": "Clicked",
      "params": [
        "React.MouseEvent"
      ]
    },
    {
      "name": "onFocus",
      "desc": "Focused",
      "params": [
        "React.FocusEvent"
      ]
    },
    {
      "name": "onBlur",
      "desc": "Blurred",
      "params": [
        "React.FocusEvent"
      ]
    }
  ],
  "access": {
    "aria": [
      "aria-label",
      "aria-describedby"
    ],
    "kb": {}
  }
}