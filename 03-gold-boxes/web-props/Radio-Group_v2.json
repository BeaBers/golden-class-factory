{
  "meta": {
    "name": "Radio-Group",
    "source": "Radix UI",
    "ver": "1.0.0",
    "date": "2026-06-13",
    "type": "web"
  },
  "sem": {
    "tag": "div",
    "container": false,
    "children": true,
    "role": "radio-group"
  },
  "props": [
    {
      "name": "value",
      "type": "string",
      "required": true,
      "default": null,
      "allowedValues": null,
      "description": "",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "disabled",
      "type": "boolean",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "",
      "uiControl": "toggle",
      "category": "state",
      "constraints": null
    },
    {
      "name": "children",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    }
  ],
  "events": [
    {
      "name": "onValueChange",
      "desc": "Value changes",
      "params": [
        "string|boolean"
      ]
    },
    {
      "name": "onClick",
      "desc": "Clicked",
      "params": [
        "React.MouseEvent"
      ]
    },
    {
      "name": "onFocus",
      "desc": "Focused",
      "params": [
        "React.FocusEvent"
      ]
    },
    {
      "name": "onBlur",
      "desc": "Blurred",
      "params": [
        "React.FocusEvent"
      ]
    }
  ],
  "access": {
    "aria": [
      "aria-label",
      "aria-describedby",
      "aria-pressed",
      "aria-checked",
      "aria-disabled"
    ],
    "kb": {
      "Space": "Toggle",
      "Enter": "Activate"
    }
  }
}