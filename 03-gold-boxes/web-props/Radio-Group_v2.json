{
  "meta": {
    "name": "Radio-Group",
    "source": "Radix UI",
    "ver": "1.0.0",
    "date": "2026-06-14",
    "type": "web"
  },
  "sem": {
    "tag": "div",
    "container": false,
    "children": true,
    "role": "radio-group"
  },
  "props": [
    {
      "name": "name",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "name (string)",
      "uiControl": "text_input",
      "category": "content",
      "constraints": null
    },
    {
      "name": "required",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Whether the field is required",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "disabled",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Whether the component is disabled",
      "uiControl": "text_input",
      "category": "state",
      "constraints": null
    },
    {
      "name": "dir",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Text direction: ltr or rtl",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "orientation",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Layout: horizontal or vertical",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "loop",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Whether navigation loops",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "defaultValue",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "The initial value",
      "uiControl": "text_input",
      "category": "content",
      "constraints": null
    },
    {
      "name": "value",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "The controlled value",
      "uiControl": "text_input",
      "category": "content",
      "constraints": null
    },
    {
      "name": "onValueChange",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "ValueChange (string)",
      "uiControl": "text_input",
      "category": "content",
      "constraints": null
    },
    {
      "name": "children",
      "type": "component",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Content of the component",
      "uiControl": "component_picker",
      "category": "content",
      "constraints": null
    }
  ],
  "events": [
    {
      "name": "onValueChange",
      "desc": "Value changes",
      "params": [
        "string|boolean"
      ]
    },
    {
      "name": "onClick",
      "desc": "Clicked",
      "params": [
        "React.MouseEvent"
      ]
    },
    {
      "name": "onFocus",
      "desc": "Focused",
      "params": [
        "React.FocusEvent"
      ]
    },
    {
      "name": "onBlur",
      "desc": "Blurred",
      "params": [
        "React.FocusEvent"
      ]
    }
  ],
  "access": {
    "aria": [
      "aria-label",
      "aria-describedby",
      "aria-pressed",
      "aria-checked",
      "aria-disabled"
    ],
    "kb": {
      "Space": "Toggle",
      "Enter": "Activate"
    }
  }
}