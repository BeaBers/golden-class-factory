{
  "meta": {
    "name": "Hover-Card",
    "source": "Radix UI",
    "ver": "1.0.0",
    "date": "2026-06-14",
    "type": "web"
  },
  "sem": {
    "tag": "div",
    "container": false,
    "children": true,
    "role": "hover-card"
  },
  "props": [
    {
      "name": "children",
      "type": "component",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Content of the component",
      "uiControl": "component_picker",
      "category": "content",
      "constraints": null
    },
    {
      "name": "open",
      "type": "boolean",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Whether the component is open/visible",
      "uiControl": "toggle",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "defaultOpen",
      "type": "boolean",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Whether initially open",
      "uiControl": "toggle",
      "category": "content",
      "constraints": null
    },
    {
      "name": "onOpenChange",
      "type": "function",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "OpenChange (function)",
      "uiControl": "code_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "openDelay",
      "type": "number",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "openDelay (number)",
      "uiControl": "slider",
      "category": "behavior",
      "constraints": {
        "min": 0
      }
    },
    {
      "name": "closeDelay",
      "type": "number",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "closeDelay (number)",
      "uiControl": "slider",
      "category": "behavior",
      "constraints": {
        "min": 0
      }
    },
    {
      "name": "container",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "ctainer (string)",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "forceMount",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "Always mount in DOM",
      "uiControl": "text_input",
      "category": "behavior",
      "constraints": null
    },
    {
      "name": "onEscapeKeyDown",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "EscapeKeyDown (string)",
      "uiControl": "text_input",
      "category": "content",
      "constraints": null
    },
    {
      "name": "onPointerDownOutside",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "PointerDownOutside (string)",
      "uiControl": "text_input",
      "category": "interaction",
      "constraints": null
    },
    {
      "name": "onFocusOutside",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "FocusOutside (string)",
      "uiControl": "text_input",
      "category": "content",
      "constraints": null
    },
    {
      "name": "onInteractOutside",
      "type": "string",
      "required": false,
      "default": null,
      "allowedValues": null,
      "description": "InteractOutside (string)",
      "uiControl": "text_input",
      "category": "content",
      "constraints": null
    }
  ],
  "events": [
    {
      "name": "onOpenChange",
      "desc": "Open state changes",
      "params": [
        "boolean"
      ]
    },
    {
      "name": "onClick",
      "desc": "Clicked",
      "params": [
        "React.MouseEvent"
      ]
    },
    {
      "name": "onFocus",
      "desc": "Focused",
      "params": [
        "React.FocusEvent"
      ]
    },
    {
      "name": "onBlur",
      "desc": "Blurred",
      "params": [
        "React.FocusEvent"
      ]
    }
  ],
  "access": {
    "aria": [
      "aria-label",
      "aria-describedby"
    ],
    "kb": {}
  }
}